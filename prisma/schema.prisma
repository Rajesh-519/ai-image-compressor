generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  AGENCY
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INACTIVE
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum JobType {
  COMPRESS
  CONVERT
  BULK
  AUDIT
}

enum CompressionMode {
  MAX
  BALANCED
  QUALITY
  CUSTOM
}

enum ImageSourceType {
  UPLOAD
  URL
  PASTE
  API
  ZIP
}

enum ImageFormat {
  JPEG
  PNG
  WEBP
  AVIF
  JXL
  HEIC
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id               String           @id @default(cuid())
  name             String?
  email            String?          @unique
  emailVerified    DateTime?
  image            String?
  stripeCustomerId String?          @unique
  defaultPlan      Plan             @default(FREE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  accounts         Account[]
  sessions         Session[]
  images           Image[]
  compressionJobs  CompressionJob[]
  subscriptions    Subscription[]
  usageTracking    UsageTracking[]
  apiKeys          APIKey[]
  ownedTeams       Team[]           @relation("TeamOwner")
  teamMemberships  TeamMembership[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Team {
  id        String           @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  owner     User             @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   TeamMembership[]
  apiKeys   APIKey[]
}

model TeamMembership {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Image {
  id               String           @id @default(cuid())
  userId           String?
  jobId            String?
  originalName     String
  originalUrl      String?
  storageUrl       String?
  sourceType       ImageSourceType
  inputFormat      ImageFormat
  outputFormat     ImageFormat?
  width            Int?
  height           Int?
  originalBytes    Int
  compressedBytes  Int?
  compressionRatio Float?
  altText          String?
  title            String?
  caption          String?
  seoFilename      String?
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  job              CompressionJob?  @relation(fields: [jobId], references: [id], onDelete: SetNull)
}

model CompressionJob {
  id               String           @id @default(cuid())
  userId           String?
  apiKeyId         String?
  status           JobStatus        @default(PENDING)
  jobType          JobType          @default(COMPRESS)
  requestedFormat  ImageFormat?
  mode             CompressionMode  @default(BALANCED)
  quality          Int              @default(78)
  contentAware     Boolean          @default(true)
  bulkCount        Int              @default(1)
  sourceUrl        String?
  resultArchiveUrl String?
  report           Json?
  errorMessage     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  completedAt      DateTime?
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiKey           APIKey?          @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  images           Image[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(INACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageTracking {
  id              String   @id @default(cuid())
  userId          String?
  apiKeyId        String?
  date            DateTime @default(now())
  imagesProcessed Int      @default(0)
  bytesSaved      BigInt   @default(0)
  auditsRun       Int      @default(0)
  apiCalls        Int      @default(0)
  createdAt       DateTime @default(now())
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiKey          APIKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
}

model APIKey {
  id        String           @id @default(cuid())
  userId    String
  teamId    String?
  name      String
  prefix    String           @unique
  hashedKey String           @unique
  createdAt DateTime         @default(now())
  lastUsedAt DateTime?
  revokedAt DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  usage     UsageTracking[]
  jobs      CompressionJob[]
}
